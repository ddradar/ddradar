    "@types/node": "^18.17.11",
    "graphql": "^16.9.0",
    "happy-dom": "^14.12.3",
    "ts-patch": "^3.2.1",
    "typescript": "^5.5.2",
    "unbuild": "^3.0.0-rc.6",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "typia": "^6.4.1",
    "zod": "^3.23.8"
  }
}
