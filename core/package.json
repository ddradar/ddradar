{
  "name": "@ddradar/core",
  "version": "2.0.0",
  "description": "Core library for DDRadar",
  "author": "Nogic <24802730+nogic1008@users.noreply.github.com>",
  "repository": "https://github.com/ddradar/ddradar",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./test/data": {
      "import": "./dist/test/data.mjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "ts-patch install && typia patch && graphql-codegen",
    "prebuild": "pnpm prepare",
    "build": "unbuild",
    "test": "vitest run"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.9",
